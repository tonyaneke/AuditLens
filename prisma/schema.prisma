generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String   @id @default(cuid())
  name               String
  email              String   @unique
  passwordHash       String
  department         String
  role               String
  sidebarAccess      Json     @default("[]")
  mustChangePassword Boolean  @default(true)
  photo              String?  // Microsoft profile picture as a data URL (fetched on SSO sign-in)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model WorkspaceData {
  id        String   @id @default("default")
  data      Json
  updatedAt DateTime @updatedAt
}

model AuditLog {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  userId    String?
  userName  String
  userEmail String
  action    String
  category  String
  summary   String
  metadata  Json?

  @@index([createdAt])
  @@index([action])
  @@index([userId])
  @@index([category])
}
